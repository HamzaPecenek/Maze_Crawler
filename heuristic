gle_environments.envs.open_spiel_env.open_spiel_env] INFO: OpenSpiel games skipped: 1.\n[kaggle_environments.envs.open_spiel_env.open_spiel_env] INFO:    snake\n1 [(0, 270, 'DONE'), (1, -413, 'DONE')]\n2 [(0, 76, 'DONE'), (1, -134, 'DONE')]\n3 [(0, 242, 'DONE'), (1, -240, 'DONE')]\n42 [(0, 313, 'DONE'), (1, -393, 'DONE')]\n123 [(0, 120, 'DONE'), (1, -200, 'DONE')]\n","output_type":"stream"}],"execution_count":3},{"id":"dab18c90-f49e-450a-89ec-60cadfd6754d","cell_type":"markdown","source":"## Package for submission\n\nKaggle accepts a `main.py` directly, but a tarball is convenient for notebook submissions. The archive must contain `main.py` at the root.","metadata":{}},{"id":"33126b0f-1289-4343-adce-01491e1670d6","cell_type":"code","source":"import tarfile, os\nwith tarfile.open('submission.tar.gz', 'w:gz') as tar:\n    tar.add('main.py', arcname='main.py')\nprint('Created submission.tar.gz:', os.path.getsize('submission.tar.gz'), 'bytes')\n","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-05-29T10:55:17.185605Z","iopub.execute_input":"2026-05-29T10:55:17.186252Z","iopub.status.idle":"2026-05-29T10:55:17.196542Z","shell.execute_reply.started":"2026-05-29T10:55:17.186200Z","shell.execute_reply":"2026-05-29T10:55:17.195749Z"}},"outputs":[{"name":"stdout","text":"Created submission.tar.gz: 3820 bytes\n","output_type":"stream"}],"execution_count":4},{"id":"903d2b4b-4f67-430e-8948-5139ebf24a23","cell_type":"markdown","source":"## Submit\n\nFrom a Kaggle notebook, use the competition submit UI or CLI. For CLI submission from a notebook version, replace `YOUR_USERNAME/crawl-agent` with the notebook slug:\n\n```bash\nkaggle competitions submit maze-crawler -k YOUR_USERNAME/crawl-agent -f submission.tar.gz -v 1 -m \"heuristic scout-worker-miner v1\"\n```\n\nFor direct local submission:\n\n```bash\nkaggle competitions submit maze-crawler -f main.py -m \"heuristic scout-worker-miner v1\"\n```","metadata":{}}]}