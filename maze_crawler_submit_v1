{"metadata":{"kernelspec":{"display_name":"Python 3","language":"python","name":"python3"},"language_info":{"name":"python","version":"3.12.13","mimetype":"text/x-python","codemirror_mode":{"name":"ipython","version":3},"pygments_lexer":"ipython3","nbconvert_exporter":"python","file_extension":".py"},"kaggle":{"accelerator":"none","dataSources":[{"sourceType":"competition","sourceId":140389,"databundleVersionId":17067703}],"dockerImageVersionId":31400,"isInternetEnabled":true,"language":"python","sourceType":"notebook","isGpuEnabled":false}},"nbformat_minor":4,"nbformat":4,"cells":[{"cell_type":"markdown","source":"# Maze Crawler — Submit *Pathfinder v1*\n\n**Create this notebook from the competition page** (New Notebook) so the `crawl` engine is available. Then:\n1. **Run all** cells. Cell 1 writes `main.py`; the rest validate it plays a full episode without crashing, give an early win-rate signal, and render a sample game.\n2. **Save Version** (commit) the notebook.\n3. Open the competition → **Submit** and submit the produced `submission.tar.gz` (or `main.py`).\n\nYou can submit up to **5 agents/day**; only your **latest 2** count for the finale.\n","metadata":{}},{"cell_type":"code","source":"%%writefile main.py\n\"\"\"\nMaze Crawler - Pathfinder v1\n============================\nA survival-first heuristic agent for the Kaggle \"crawl\" competition.\n\nCore idea (derived from the rules):\n  * The Factory is indestructible to everything except an enemy Factory, so you\n    almost never die in combat -- you die by falling below the scrolling southern\n    boundary. Therefore the #1 job is: keep the factory moving NORTH, efficiently,\n    forever.\n  * The factory moves once every 2 turns; the boundary eventually scrolls once per\n    turn. So we must (a) build a northward buffer early, (b) ALWAYS use JUMP when\n    available (it nets +1 extra row per 20 turns and bypasses walls), and (c) never\n    waste a turn stuck against a wall we can route around.\n  * Scouts (vision 5, move every turn) reveal the maze ahead so the factory can\n    path efficiently. Workers knock down walls that block the lane. We bank a little\n    energy (crystals + emergency transfers) so the factory never starves and so we\n    win the step-500 total-energy tiebreaker.\n\nRobustness: the whole decision is wrapped in try/except. If anything goes wrong we\nfall back to \"factory north, everyone north\" so the bot never crashes (a crashing\nagent forfeits the episode).\n\nTypes: 0=Factory, 1=Scout, 2=Worker, 3=Miner\nWall bits: N=1, E=2, S=4, W=8\nobs.robots[uid] = [type, col, row, energy, owner, move_cd, jump_cd, build_cd]\nobs.walls index = (row - southBound) * width + col ; value -1 = undiscovered\n\"\"\"\n\nfrom collections import deque\n\n# Module-level state persists across turns within one episode/process.\nSTATE = {\"step\": -1, \"last_south\": None}\n\nDIRS = {\"NORTH\": (0, 1), \"SOUTH\": (0, -1), \"EAST\": (1, 0), \"WEST\": (-1, 0)}\nDIRBIT = {\"NORTH\": 1, \"EAST\": 2, \"SOUTH\": 4, \"WEST\": 8}\n\nFACTORY, SCOUT, WORKER, MINER = 0, 1, 2, 3\n\nTARGET_SCOUTS = 2\nTARGET_WORKERS = 2\n\n\ndef _cfg(config, name, default):\n    \"\"\"Safe config accessor (config behaves like an attribute/dict struct).\"\"\"\n    try:\n        v = getattr(config, name)\n        if v is not None:\n            return v\n    except Exception:\n        pass\n    try:\n        return config[name]\n    except Exception:\n        return default\n\n\ndef _obs(obs, name, default):\n    try:\n        v = getattr(obs, name)\n        if v is not None:\n            return v\n    except Exception:\n        pass\n    try:\n        return obs[name]\n    except Exception:\n        return default\n\n\ndef agent(obs, config):\n    try:\n        return _decide(obs, config)\n    except Exception:\n        actions = {}\n        try:\n            me = _obs(obs, \"player\", 0)\n            for uid, d in _obs(obs, \"robots\", {}).items():\n                if d[4] == me:\n                    actions[uid] = \"BUILD_WORKER\" if d[0] == FACTORY else \"NORTH\"\n        except Exception:\n            pass\n        return actions\n\n\ndef _decide(obs, config):\n    W = int(_cfg(config, \"width\", 20))\n    walls = list(_obs(obs, \"walls\", []))\n    south = int(_obs(obs, \"southBound\", 0))\n    north = int(_obs(obs, \"northBound\", south + (len(walls) // W if W else 20) - 1))\n    me = _obs(obs, \"player\", 0)\n    robots = _obs(obs, \"robots\", {})\n    crystals = _obs(obs, \"crystals\", {})\n    episode_steps = int(_cfg(config, \"episodeSteps\", 501))\n\n    scout_cost = int(_cfg(config, \"scoutCost\", 50))\n    worker_cost = int(_cfg(config, \"workerCost\", 200))\n    remove_cost = int(_cfg(config, \"wallRemoveCost\", 100))\n\n    # ---- step bookkeeping (reset if a fresh game reused this process) ----\n    last_south = STATE.get(\"last_south\")\n    if last_south is not None and south < last_south - 2:\n        STATE[\"step\"] = -1\n    STATE[\"step\"] += 1\n    STATE[\"last_south\"] = south\n    step = STATE[\"step\"]\n    turns_left = max(20, episode_steps - step)\n\n    # ---- wall helpers ----\n    def wbits(col, row):\n        if not (0 <= col < W):\n            return None\n        i = (row - south) * W + col\n        if 0 <= i < len(walls):\n            v = walls[i]\n            return None if v == -1 else v\n        return None\n\n    def on_board(col, row):\n        return 0 <= col < W and south <= row <= north\n\n    def can_step(col, row, dirn):\n        b = wbits(col, row)\n        if b is None:\n            return False\n        if b & DIRBIT[dirn]:\n            return False\n        dx, dy = DIRS[dirn]\n        nc, nr = col + dx, row + dy\n        return on_board(nc, nr)\n\n    # ---- gather my / enemy units ----\n    my_units = {}\n    enemy_cells = set()\n    enemy_factory_cells = set()\n    for uid, d in robots.items():\n        rtype, col, row, energy, owner = d[0], d[1], d[2], d[3], d[4]\n        if owner == me:\n            my_units[uid] = d\n        else:\n            enemy_cells.add((col, row))\n            if rtype == FACTORY:\n                enemy_factory_cells.add((col, row))\n\n    factory_uid = None\n    factory = None\n    scouts, workers, miners = [], [], []\n    for uid, d in my_units.items():\n        t = d[0]\n        if t == FACTORY:\n            factory_uid, factory = uid, d\n        elif t == SCOUT:\n            scouts.append((uid, d))\n        elif t == WORKER:\n            workers.append((uid, d))\n        elif t == MINER:\n            miners.append((uid, d))\n\n    actions = {}\n    claimed = set()\n    friendly_final = set()\n\n    factory_pos = (factory[1], factory[2]) if factory else None\n    factory_energy = factory[3] if factory else 0\n\n    def crystal_at(col, row):\n        return (\"%d,%d\" % (col, row)) in crystals\n\n    def pick_move(col, row, prefer, avoid_enemy=True, allow_south=False, col_bias=None):\n        order = list(prefer)\n        seen = set()\n        order = [d for d in order if not (d in seen or seen.add(d))]\n        if not allow_south and \"SOUTH\" in order:\n            order.remove(\"SOUTH\")\n\n        best = None\n        best_score = None\n        for dirn in order:\n            if not can_step(col, row, dirn):\n                continue\n            dx, dy = DIRS[dirn]\n            nc, nr = col + dx, row + dy\n            cell = (nc, nr)\n            if cell in claimed:\n                continue\n            if avoid_enemy and cell in enemy_cells:\n                continue\n            score = order.index(dirn)\n            if crystal_at(nc, nr):\n                score -= 100\n            if col_bias is not None:\n                score += abs(nc - col_bias) * 0.01\n            if best_score is None or score < best_score:\n                best_score = score\n                best = (dirn, cell)\n        if best is None:\n            return \"IDLE\", (col, row)\n        return best[0], best[1]\n\n    # ===================================================================\n    # 1) NON-FACTORY UNITS FIRST (so the factory knows which cells vacate)\n    # ===================================================================\n\n    # ----- Scouts: spread out and reveal the path north -----\n    for i, (uid, d) in enumerate(scouts):\n        col, row, energy = d[1], d[2], d[3]\n        if energy <= 0:\n            friendly_final.add((col, row)); claimed.add((col, row)); continue\n        if i % 2 == 0:\n            prefer = [\"NORTH\", \"EAST\", \"WEST\"]\n            bias = min(W - 1, col + 4)\n        else:\n            prefer = [\"NORTH\", \"WEST\", \"EAST\"]\n            bias = max(0, col - 4)\n        act, cell = pick_move(col, row, prefer, col_bias=bias)\n        actions[uid] = act\n        friendly_final.add(cell); claimed.add(cell)\n\n    # ----- Workers: vanguard wall-clearing just ahead of the factory -----\n    fcol = factory_pos[0] if factory_pos else W // 2\n    for uid, d in workers:\n        col, row, energy = d[1], d[2], d[3]\n        b = wbits(col, row)\n        buf = row - south\n\n        donated = False\n        if factory_pos is not None and factory_energy < 150 and energy > 20:\n            if (col, row + 1) == factory_pos: actions[uid] = \"TRANSFER_NORTH\"; donated = True\n            elif (col, row - 1) == factory_pos: actions[uid] = \"TRANSFER_SOUTH\"; donated = True\n            elif (col + 1, row) == factory_pos: actions[uid] = \"TRANSFER_EAST\"; donated = True\n            elif (col - 1, row) == factory_pos: actions[uid] = \"TRANSFER_WEST\"; donated = True\n        if donated:\n            friendly_final.add((col, row)); claimed.add((col, row)); continue\n\n        if (b is not None) and (b & 1) and energy > remove_cost + 5 \\\n                and row < north and buf >= 1:\n            actions[uid] = \"REMOVE_NORTH\"\n            friendly_final.add((col, row)); claimed.add((col, row)); continue\n\n        prefer = [\"NORTH\", \"EAST\", \"WEST\"]\n        act, cell = pick_move(col, row, prefer, col_bias=fcol)\n        actions[uid] = act\n        friendly_final.add(cell); claimed.add(cell)\n\n    # ----- Miners (v1 does not build them, but be graceful if present) -----\n    for uid, d in miners:\n        col, row = d[1], d[2]\n        act, cell = pick_move(col, row, [\"NORTH\", \"EAST\", \"WEST\"], col_bias=fcol)\n        actions[uid] = act\n        friendly_final.add(cell); claimed.add(cell)\n\n    # ===================================================================\n    # 2) FACTORY -- never die; build the army early; race north\n    # ===================================================================\n    if factory is not None:\n        col, row, energy = factory[1], factory[2], factory[3]\n        jump_cd = factory[6] if len(factory) > 6 else 0\n        build_cd = factory[7] if len(factory) > 7 else 0\n        fb = wbits(col, row)\n        north_wall = (fb is not None) and (fb & 1)\n        buffer = row - south\n        early_econ = step < 130\n\n        def north_cell_safe():\n            nc = (col, row + 1)\n            if nc in enemy_factory_cells:\n                return False\n            if nc in friendly_final:\n                return False\n            return True\n\n        def jump_ok():\n            return jump_cd == 0 and (row + 2) <= north\n\n        n_scouts = len(scouts)\n        n_workers = len(workers)\n\n        spawn_free = (not north_wall) and (row + 1 <= north) \\\n            and ((col, row + 1) not in friendly_final) \\\n            and ((col, row + 1) not in enemy_cells)\n        build_action = None\n        if build_cd == 0 and spawn_free and early_econ and buffer >= 3:\n            if n_scouts < TARGET_SCOUTS and (energy - scout_cost) > (turns_left + 60):\n                build_action = \"BUILD_SCOUT\"\n            elif n_workers < TARGET_WORKERS and (energy - worker_cost) > (turns_left + 60):\n                build_action = \"BUILD_WORKER\"\n\n        def northward_move():\n            if jump_ok():\n                return \"JUMP_NORTH\"\n            if not north_wall and (row + 1 <= north) and north_cell_safe():\n                return \"NORTH\"\n            fm = _bfs_first_step((col, row), can_step)\n            if fm is not None:\n                dx, dy = DIRS[fm]\n                if (col + dx, row + dy) not in friendly_final and \\\n                   (col + dx, row + dy) not in enemy_factory_cells:\n                    return fm\n            for dirn in (\"EAST\", \"WEST\", \"NORTH\"):\n                if can_step(col, row, dirn):\n                    dx, dy = DIRS[dirn]\n                    cell = (col + dx, row + dy)\n                    if cell not in friendly_final and cell not in claimed \\\n                       and cell not in enemy_factory_cells:\n                        return dirn\n            return \"IDLE\"\n\n        if build_action is not None:\n            actions[factory_uid] = build_action\n        else:\n            actions[factory_uid] = northward_move()\n\n    return actions\n\n\ndef _bfs_first_step(start, can_step):\n    \"\"\"BFS over the known passable graph; return the first move (from `start`)\n    toward the reachable cell with the greatest row. None if no northward gain.\"\"\"\n    visited = {start}\n    firstmove = {start: None}\n    q = deque([start])\n    best = start\n    best_row = start[1]\n    while q:\n        cur = q.popleft()\n        c, r = cur\n        if r > best_row:\n            best_row = r\n            best = cur\n        for dirn, (dx, dy) in DIRS.items():\n            if not can_step(c, r, dirn):\n                continue\n            nxt = (c + dx, r + dy)\n            if nxt in visited:\n                continue\n            visited.add(nxt)\n            firstmove[nxt] = firstmove[cur] if firstmove[cur] is not None else dirn\n            q.append(nxt)\n    if best_row <= start[1]:\n        return None\n    return firstmove.get(best)\n","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-05-27T05:23:37.214536